# LLM endpoint — provider-agnostic
LLM_API_KEY=your-api-key-here

# Model overrides (optional — benchmark.yaml defaults shown)
# Uncomment to override:
# MODEL_URL=https://open.bigmodel.cn/api/paas/v4/
# MODEL_PROTOCOL=openai
# MODEL_NAME=glm-5.2

# Examples for other providers:
# MODEL_URL=https://api.anthropic.com
# MODEL_PROTOCOL=anthropic
# MODEL_NAME=claude-sonnet-4-5

# MODEL_URL=https://api.openai.com/v1
# MODEL_PROTOCOL=openai
# MODEL_NAME=gpt-4o

# Run settings (optional)
# REPETITIONS=3
# TASK_TIMEOUT=600
HARNESS_IMAGE=harness:latest
