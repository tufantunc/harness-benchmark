# LLM provider — default ZAI (GLM 5.2)
# Get your key from https://z.ai
ZAI_API_KEY=your-zai-api-key-here

# Model to benchmark (provider/model format)
BENCHMARK_MODEL=glm-5.2

# Optional: OpenCode Zen provider (alternative way to access models)
# OPENCODE_API_KEY=

# Optional: swap to a different provider for comparison runs
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Docker image name (built once, reused across runs)
HARNESS_IMAGE=harness:latest

# Repetitions per (harness × task) combination
REPETITIONS=3

# Per-task timeout in seconds
TASK_TIMEOUT=600
