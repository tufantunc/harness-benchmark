# LLM endpoint — provider-agnostic (URL + protocol in benchmark.yaml)
# Get your key from your model provider (e.g., https://z.ai for GLM)
LLM_API_KEY=your-api-key-here

# Docker image name (built once, reused across runs)
HARNESS_IMAGE=harness:latest

# Repetitions per (harness x task) combination
REPETITIONS=3

# Per-task timeout in seconds
TASK_TIMEOUT=600

# --- Model overrides (optional) ---
# benchmark.yaml defines default url/protocol/name.
# Override via CLI flags instead of editing here:
#   ./scripts/benchmark.sh \
#     --model-url https://api.anthropic.com \
#     --model-protocol anthropic \
#     --model-name claude-sonnet-4-5
